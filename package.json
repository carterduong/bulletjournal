{
  "name": "bulletjournal",
  "version": "2.0.0",
  "description": "A minimalist digital weekly bullet journal.",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent || ''; if (!ua.includes('pnpm')) { console.error('Please use pnpm to install dependencies (npm/yarn are not supported).'); process.exit(1); }\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carterduong/bulletjournal.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/carterduong/bulletjournal/issues"
  },
  "homepage": "https://github.com/carterduong/bulletjournal#readme",
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.3.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
